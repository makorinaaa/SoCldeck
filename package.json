{
  "name": "socialdeck",
  "version": "1.7.1",
  "description": "TweetDeck風マルチカラムクライアント (X + Bluesky)",
  "main": "src/main.js",
  "scripts": {
    "test": "node --test tests/*.test.js",
    "start": "electron .",
    "dev": "electron . --dev",
    "build-win": "electron-builder --win",
    "build-mac": "electron-builder --mac",
    "build-linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.socialdeck.app",
    "productName": "SocialDeck",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    },
    "asar": true,
    "asarUnpack": [
      "**/ffmpeg-static/**",
      "**/node_modules/@cliqz/adblocker-electron/**",
      "**/node_modules/@cliqz/adblocker/**",
      "**/node_modules/node-fetch/**"
    ],
    "files": [
      "src/**/*",
      "node_modules/**/*"
    ]
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.0.0"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@cliqz/adblocker-electron": "1.34.0",
    "ffmpeg-static": "5.3.0",
    "fluent-ffmpeg": "2.1.3",
    "node-fetch": "3.3.2"
  }
}
